		sourceColumn: [Ano Mes]

		annotation SummarizationSetBy = Automatic

	partition Dim_Calendario = calculated
		mode: import
		source =
				
				VAR DataMinima = MIN(Fato_Vendas[Data])
				VAR DataMaxima = MAX(Fato_Vendas[Data])
				RETURN
				ADDCOLUMNS (
				    CALENDAR (DataMinima, DataMaxima),
				    "Ano", YEAR ( [Date] ),
				    "Mes Num", MONTH ( [Date] ),
				    "Nome Mes", FORMAT ( [Date], "MMMM", "pt-BR" ),
				    "Trimestre", "T" & QUARTER ( [Date] ),
				    "Ano Mes", FORMAT ( [Date], "YYYY-MM" )
				)

	annotation PBI_Id = 22b0b9689c8a4763b2389f99bd3e804b

